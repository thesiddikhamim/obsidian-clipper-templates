{
	"schemaVersion": "0.1.0",
	"name": "Goodreads",
	"behavior": "create",
	"noteContentFormat": "![image]({{schema:image}})\n",
	"properties": [
		{
			"name": "categories",
			"value": "[[Books]]",
			"type": "multitext"
		},
		{
			"name": "title",
			"value": "{{selector:.BookPageTitleSection__title h1}}",
			"type": "text"
		},
		{
			"name": "author",
			"value": "{{selector:.ContributorLink__name|unique|wikilink|join}}",
			"type": "multitext"
		},
		{
			"name": "genre",
			"value": "{{selector:.BookPageMetadataSection__genres .BookPageMetadataSection__genreButton|wikilink|join}}",
			"type": "multitext"
		},
		{
			"name": "pages",
			"value": "{{selector:p[data-testid='pagesFormat']|split:\\\", \\\"|slice:0|split:\\\" \\\"|slice:0}}",
			"type": "number"
		},
		{
			"name": "published",
			"value": "{{selector:p[data-testid='publicationInfo']|split:\\\" \\\"|last}}",
			"type": "date"
		},
		{
			"name": "scoreGr",
			"value": "{{selector:.RatingStatistics__rating|first|round:2}}",
			"type": "number"
		},
		{
			"name": "ratingsCount",
			"value": "{{selector:[data-testid='ratingsCount']}}",
			"type": "text"
		},
		{
			"name": "myRating",
			"value": "{{selector:.BookRatingStars span[role='group']?aria-label|split:\\\\\" \\\\\"|slice:1,2|first}}",
			"type": "text"
		},
		{
			"name": "cover",
			"value": "{{selector:.BookCover__image img?src|first}}",
			"type": "text"
		},
		{
			"name": "isbn",
			"value": "{{selector:.DescList|split:\\\"ISBN\\\"|slice:1,2|split:\\\" \\\"|first}}",
			"type": "text"
		},
		{
			"name": "language",
			"value": "{{selector:.DescList|split:\\\"Language\\\"|last}}",
			"type": "text"
		},
		{
			"name": "created",
			"value": "{{date}}",
			"type": "date"
		},
		{
			"name": "tags",
			"value": "books, read",
			"type": "multitext"
		},
		{
			"name": "description",
			"value": "{{selector:.BookPageMetadataSection__description}}",
			"type": "text"
		}
	],
	"triggers": [
		"https://www.goodreads.com/book/"
	],
	"noteNameFormat": "{{selector:.BookPageTitleSection__title h1}}",
	"path": "Books"
}
